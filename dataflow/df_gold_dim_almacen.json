{
	"name": "df_gold_dim_almacen",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_agencia_almacenes",
						"type": "DatasetReference"
					},
					"name": "almacen"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_almacen",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          almacen_id as integer,",
				"          nombre as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          direccion as string,",
				"          capacidad_m3 as integer,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT almacen_id, nombre, municipio, departamento,\\n       direccion, capacidad_m3, estado\\nFROM silver.agencia_almacenes',",
				"     format: 'query') ~> almacen",
				"almacen sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          almacen_sk as integer,",
				"          almacen_id as integer,",
				"          nombre as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          direccion as string,",
				"          capacidad_m3 as integer,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          almacen_id,",
				"          nombre,",
				"          municipio,",
				"          departamento,",
				"          direccion,",
				"          capacidad_m3,",
				"          estado",
				"     )) ~> sink1"
			]
		}
	}
}