{
	"name": "df_bronze_segip_cargar_datos",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "segip_personas",
						"type": "DatasetReference"
					},
					"name": "Personas"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "bronze_segip_personas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          ci as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          fecha_nacimiento as string,",
				"          genero as string,",
				"          estado_civil as string,",
				"          ci_conyuge as string,",
				"          numero_hijos as string,",
				"          ci_padre as string,",
				"          ci_madre as string,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string,",
				"          fecha_emision as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> Personas",
				"Personas sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          ci as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          fecha_nacimiento as string,",
				"          genero as string,",
				"          estado_civil as string,",
				"          ci_conyuge as string,",
				"          numero_hijos as string,",
				"          ci_padre as string,",
				"          ci_madre as string,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string,",
				"          fecha_emision as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          ci,",
				"          nombres,",
				"          apellido_paterno,",
				"          apellido_materno,",
				"          fecha_nacimiento,",
				"          genero,",
				"          estado_civil,",
				"          ci_conyuge,",
				"          numero_hijos,",
				"          ci_padre,",
				"          ci_madre,",
				"          profesion,",
				"          nivel_estudios,",
				"          municipio_residencia,",
				"          fecha_emision",
				"     )) ~> sink1"
			]
		}
	}
}