					"name": "Despachos"
				},
				{
					"dataset": {
						"referenceName": "bronze_agencia_recepciones",
						"type": "DatasetReference"
					},
					"name": "Recepciones"
				},
				{
					"dataset": {
						"referenceName": "bronze_agencia_transportistas",
						"type": "DatasetReference"
					},
					"name": "Transportistas"
				},
				{
					"dataset": {
						"referenceName": "bronze_agencia_vehiculos",
						"type": "DatasetReference"
					},
					"name": "Vehiculos"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_agencia_almacenes",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "silver_agencia_despachos",
						"type": "DatasetReference"
					},
					"name": "sink2"
				},
				{
					"dataset": {
						"referenceName": "silver_agencia_recepciones",
						"type": "DatasetReference"
					},
					"name": "sink3"
				},
				{
					"dataset": {
						"referenceName": "silver_agencia_transportistas",
						"type": "DatasetReference"
					},
					"name": "sink4"
				},
				{
					"dataset": {
						"referenceName": "silver_agencia_vehiculos",
						"type": "DatasetReference"
					},
					"name": "sink5"
				}
			],
			"transformations": [
				{
					"name": "Normalizar"
				},
				{
					"name": "TipoDato"
				},
				{
					"name": "Corrige"
				},
				{
					"name": "ints"
				},
				{
					"name": "normal"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          almacen_id as string,",
				"          nombre as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          direccion as string,",
				"          capacidad_m3 as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    almacen_id,\\r\\n    TRIM(nombre)        AS nombre,\\r\\n    TRIM(municipio)     AS municipio,\\r\\n    TRIM(departamento)  AS departamento,\\r\\n    TRIM(direccion)     AS direccion,\\r\\n    capacidad_m3,\\r\\n    TRIM(estado) AS estado\\r\\nFROM bronze.agencia_almacenes',",
				"     format: 'query') ~> Almacenes",
				"source(output(",
				"          despacho_id as string,",
				"          recepcion_id as string,",
				"          nro_lote as string,",
				"          almacen_id as string,",
				"          transportista_id as string,",
				"          vehiculo_id as string,",
				"          fecha_despacho as string,",
				"          cantidad_despachada as string,",
				"          centro_destino as string,",
				"          estado as string,",
				"          responsable as string,",
				"          nro_guia_despacho as string,",
				"          fecha_llegada as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    despacho_id,\\r\\n    recepcion_id,\\r\\n    TRIM(nro_lote)                             AS nro_lote,\\r\\n    almacen_id,\\r\\n    transportista_id,\\r\\n    vehiculo_id,\\r\\n    TRIM(fecha_despacho)                       AS fecha_despacho,\\r\\n    cantidad_despachada,\\r\\n    TRIM(centro_destino)     AS centro_destino,\\r\\n    TRIM(estado)                                     AS estado,\\r\\n    TRIM(responsable) AS responsable,\\r\\n    TRIM(nro_guia_despacho)                   AS nro_guia_despacho,\\r\\n    NULLIF(TRIM(fecha_llegada), \\'\\')           AS fecha_llegada\\r\\nFROM bronze.agencia_despachos\\r\\nWHERE NULLIF(TRIM(nro_lote), \\'\\') IS NOT NULL',",
				"     format: 'query') ~> Despachos",
				"source(output(",
				"          recepcion_id as string,",
				"          nro_lote as string,",
				"          almacen_id as string,",
				"          transportista_id as string,",
				"          vehiculo_id as string,",
				"          fecha_recepcion as string,",
				"          cantidad_recibida as string,",
				"          unidad as string,",
				"          condicion as string,",
				"          estado as string,",
				"          responsable as string,",
				"          nro_guia_remision as string,",
				"          temperatura_llegada as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    recepcion_id,\\r\\n    TRIM(nro_lote)                             AS nro_lote,\\r\\n    almacen_id,\\r\\n    transportista_id,\\r\\n    vehiculo_id,\\r\\n    TRIM(fecha_recepcion)                      AS fecha_recepcion,\\r\\n    cantidad_recibida,\\r\\n    LOWER(TRIM(unidad))                        AS unidad,\\r\\n    LOWER(TRIM(condicion))           AS condicion,\\r\\n    LOWER(TRIM(estado))         AS estado,\\r\\n    NULLIF(LOWER(TRIM(responsable)), \\'\\') AS responsable,\\r\\n    TRIM(nro_guia_remision)                   AS nro_guia_remision,\\r\\n    NULLIF(TRIM(temperatura_llegada), \\'\\')     AS temperatura_llegada\\r\\nFROM bronze.agencia_recepciones\\r\\nWHERE NULLIF(TRIM(nro_lote), \\'\\') IS NOT NULL',",
				"     format: 'query') ~> Recepciones",
				"source(output(",
				"          transportista_id as string,",
				"          razon_social as string,",
				"          nit as string,",
				"          municipio as string,",
				"          contacto as string,",
				"          telefono as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    transportista_id,\\r\\n    TRIM(razon_social)  AS razon_social,\\r\\n    TRIM(nit)           AS nit,\\r\\n    TRIM(municipio)     AS municipio,\\r\\n    TRIM(contacto)      AS contacto,\\r\\n    TRIM(telefono)      AS telefono,\\r\\n    TRIM(estado) AS estado\\r\\nFROM bronze.agencia_transportistas',",
				"     format: 'query') ~> Transportistas",
				"source(output(",
				"          vehiculo_id as string,",
				"          transportista_id as string,",
				"          descripcion as string,",
				"          placa as string,",
				"          tipo as string,",
				"          capacidad_kg as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    vehiculo_id,\\r\\n    transportista_id,\\r\\n    TRIM(descripcion)   AS descripcion,\\r\\n    UPPER(TRIM(placa))  AS placa,\\r\\n    TRIM(tipo) AS tipo,\\r\\n    capacidad_kg,\\r\\n    TRIM(estado) AS estado\\r\\nFROM bronze.agencia_vehiculos',",
				"     format: 'query') ~> Vehiculos",
				"Almacenes derive(almacen_id = toInteger(almacen_id),",
				"          capacidad_m3 = toInteger(capacidad_m3)) ~> Normalizar",
				"Despachos derive(despacho_id = toInteger(despacho_id),",
				"          recepcion_id = toInteger(recepcion_id),",
				"          almacen_id = toInteger(almacen_id),",
				"          transportista_id = toInteger(transportista_id),",
				"          vehiculo_id = toInteger(vehiculo_id)) ~> TipoDato",
				"TipoDato derive(fecha_despacho = iif(isNull(fecha_despacho) || trim(toString(fecha_despacho)) == '',\r",
				"    toDate(null()),\r",
				"iif(regexMatch(trim(toString(fecha_despacho)), '[0-9]{2}-[0-9]{2}-[0-9]{4}'),\r",
				"    toDate(trim(toString(fecha_despacho)), 'dd-MM-yyyy'),\r",
				"iif(regexMatch(trim(toString(fecha_despacho)), '[0-9]{4}-[0-9]{2}-[0-9]{2}'),\r",
				"    toDate(trim(toString(fecha_despacho)), 'yyyy-MM-dd'),\r",
				"iif(regexMatch(trim(toString(fecha_despacho)), '[0-9]{2}/[0-9]{2}/[0-9]{4}') && toInteger(left(trim(toString(fecha_despacho)),2)) > 12,\r",
				"    toDate(trim(toString(fecha_despacho)), 'dd/MM/yyyy'),\r",
				"    toDate(trim(toString(fecha_despacho)), 'MM/dd/yyyy')\r",
				")))),",
				"          fecha_llegada = iif(isNull(fecha_llegada) || trim(toString(fecha_llegada)) == '',\r",
				"    toDate(null()),\r",
				"iif(regexMatch(trim(toString(fecha_llegada)), '[0-9]{2}-[0-9]{2}-[0-9]{4}'),\r",
				"    toDate(trim(toString(fecha_llegada)), 'dd-MM-yyyy'),\r",
				"iif(regexMatch(trim(toString(fecha_llegada)), '[0-9]{4}-[0-9]{2}-[0-9]{2}'),\r",
				"    toDate(trim(toString(fecha_llegada)), 'yyyy-MM-dd'),\r",
				"iif(regexMatch(trim(toString(fecha_llegada)), '[0-9]{2}/[0-9]{2}/[0-9]{4}') && toInteger(left(trim(toString(fecha_llegada)),2)) > 12,\r",
				"    toDate(trim(toString(fecha_llegada)), 'dd/MM/yyyy'),\r",
				"    toDate(trim(toString(fecha_llegada)), 'MM/dd/yyyy')\r",
				")))),",
				"          estado = iif(lower(trim(estado))=='deespachado' || lower(trim(estado))=='despachado', 'Despachado', iif(lower(trim(estado))=='devuelto','Devuelto', iif(lower(trim(estado))=='entregado','Entregado', initCap(lower(trim(estado)))))),",
				"          responsable = iif(isNull(trim(responsable)) || trim(responsable)=='', toString(null()), initCap(lower(regexReplace(trim(responsable),'\\\\s+',' ')))),",
				"          centro_destino = initCap(lower(regexReplace(trim(centro_destino), '\\\\s+', ' '))),",
				"          cantidad_despachada = toInteger(toDecimal(trim(toString(\r",
				"cantidad_despachada)), 10, 2))) ~> Corrige",
				"Recepciones derive(recepcion_id = toInteger(recepcion_id),",
				"          almacen_id = toInteger(almacen_id),",
				"          transportista_id = toInteger(transportista_id),",
				"          vehiculo_id = toInteger(vehiculo_id),",
				"          cantidad_recibida = toInteger(toDecimal(trim(toString(\r",
				"cantidad_recibida)), 10, 2)),",
				"          temperatura_llegada = iif(isNull(trim(temperatura_llegada)) || trim(temperatura_llegada)=='', toDecimal(null()), toDecimal(temperatura_llegada,10,2))) ~> ints",
				"ints derive(estado = iif(regexMatch(lower(trim(estado)), '.*recib.*'), 'Recibido', initCap(lower(trim(estado)))),",
				"          unidad = lower(trim(unidad)),",
				"          fecha_recepcion = iif(isNull(fecha_recepcion) || trim(toString(fecha_recepcion)) == '',\r",
				"    toDate(null()),\r",
				"iif(regexMatch(trim(toString(fecha_recepcion)), '[0-9]{2}-[0-9]{2}-[0-9]{4}'),\r",
				"    toDate(trim(toString(fecha_recepcion)), 'dd-MM-yyyy'),\r",
				"iif(regexMatch(trim(toString(fecha_recepcion)), '[0-9]{4}-[0-9]{2}-[0-9]{2}'),\r",
				"    toDate(trim(toString(fecha_recepcion)), 'yyyy-MM-dd'),\r",
				"iif(regexMatch(trim(toString(fecha_recepcion)), '[0-9]{2}/[0-9]{2}/[0-9]{4}') && toInteger(left(trim(toString(fecha_recepcion)),2)) > 12,\r",
				"    toDate(trim(toString(fecha_recepcion)), 'dd/MM/yyyy'),\r",
				"    toDate(trim(toString(fecha_recepcion)), 'MM/dd/yyyy')\r",
				")))),",
				"          responsable = initCap(lower(trim(responsable))),",
				"          condicion = initCap(lower(trim(condicion)))) ~> normal",
				"Transportistas derive(transportista_id = toInteger(transportista_id)) ~> derivedColumn1",
				"Vehiculos derive(vehiculo_id = toInteger(vehiculo_id),",
				"          transportista_id = toInteger(transportista_id),",
				"          capacidad_kg = toInteger(capacidad_kg)) ~> derivedColumn2",
				"Normalizar sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          almacen_id as integer,",
				"          nombre as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          direccion as string,",
				"          capacidad_m3 as integer,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1",
				"Corrige sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          despacho_id as integer,",
				"          recepcion_id as integer,",
				"          nro_lote as string,",
				"          almacen_id as integer,",
				"          transportista_id as integer,",
				"          vehiculo_id as integer,",
				"          empresa_origen as string,",
				"          fecha_despacho as date,",
				"          fecha_llegada as date,",
				"          cantidad_despachada as decimal(12,2),",
				"          centro_destino as string,",
				"          estado as string,",
				"          responsable as string,",
				"          nro_guia_despacho as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          despacho_id,",
				"          recepcion_id,",
				"          nro_lote,",
				"          almacen_id,",
				"          transportista_id,",
				"          vehiculo_id,",
				"          fecha_despacho,",
				"          fecha_llegada,",
				"          cantidad_despachada,",
				"          centro_destino,",
				"          estado,",
				"          responsable,",
				"          nro_guia_despacho",
				"     )) ~> sink2",
				"normal sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          recepcion_id as integer,",
				"          nro_lote as string,",
				"          almacen_id as integer,",
				"          transportista_id as integer,",
				"          vehiculo_id as integer,",
				"          empresa_origen as string,",
				"          fecha_recepcion as date,",
				"          cantidad_recibida as decimal(12,2),",
				"          unidad as string,",
				"          condicion as string,",
				"          estado as string,",
				"          responsable as string,",
				"          nro_guia_remision as string,",
				"          temperatura_llegada as decimal(6,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink3",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          transportista_id as integer,",
				"          razon_social as string,",
				"          nit as string,",
				"          municipio as string,",
				"          contacto as string,",
				"          telefono as string,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          transportista_id,",
				"          razon_social,",
				"          nit,",
				"          municipio,",
				"          contacto,",
				"          telefono,",
				"          estado",
				"     )) ~> sink4",
				"derivedColumn2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          vehiculo_id as integer,",
				"          transportista_id as integer,",
				"          descripcion as string,",
				"          placa as string,",
				"          tipo as string,",
				"          capacidad_kg as integer,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          vehiculo_id,",
				"          transportista_id,",
				"          descripcion,",
				"          placa,",
				"          tipo,",
				"          capacidad_kg,",
				"          estado",
				"     )) ~> sink5"
			]
		}
	}
}