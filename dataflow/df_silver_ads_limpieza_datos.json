{
	"name": "df_silver_ads_limpieza_datos",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_agencia_almacenes",
						"type": "DatasetReference"
					},
					"name": "Almacenes"
				},
				{
					"dataset": {
						"referenceName": "bronze_agencia_despachos",
						"type": "DatasetReference"
