			"scriptLines": [
				"source(output(",
				"          boleta_id as string,",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    boleta_id,\\r\\n    control_id,\\r\\n    REPLACE(TRIM(ci_beneficiaria), \\'-\\', \\'\\')   AS ci_beneficiaria,\\r\\n    TRIM(nro_boleta)                           AS nro_boleta,\\r\\n    TRIM(fecha_emision)                        AS fecha_emision,\\r\\n    TRIM(estado)              AS estado\\r\\nFROM bronze.sup_boletas\\r\\nWHERE NULLIF(REPLACE(TRIM(ci_beneficiaria), \\'-\\', \\'\\'), \\'\\') IS NOT NULL',",
				"     format: 'query') ~> Boletas",
				"source(output(",
				"          paquete_id as string,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as string,",
				"          costo_estimado_bs as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    paquete_id,\\r\\n    TRIM(nombre)                               AS nombre,\\r\\n    TRIM(contenido)                            AS contenido,\\r\\n    peso_estandar_kg,\\r\\n    costo_estimado_bs\\r\\nFROM bronze.sup_catalogo_paquetes\\r\\nWHERE NULLIF(TRIM(nombre), \\'\\') IS NOT NULL',",
				"     format: 'query') ~> CatalogoPaquetes",
				"source(output(",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          semana_gestacion as string,",
				"          peso_madre_kg as string,",
				"          presion_arterial as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    control_id,\\r\\n    TRIM(ci_beneficiaria) AS ci_beneficiaria,\\r\\n    establecimiento_id,\\r\\n    nro_control,\\r\\n    fecha_control,\\r\\n    NULLIF(semana_gestacion, \\'\\')              AS semana_gestacion,\\r\\n    NULLIF(peso_madre_kg, \\'\\')                 AS peso_madre_kg,\\r\\n    NULLIF(TRIM(presion_arterial), \\'\\')        AS presion_arterial\\r\\nFROM bronze.sup_controles\\r\\nWHERE NULLIF(REPLACE(TRIM(ci_beneficiaria), \\'-\\', \\'\\'), \\'\\') IS NOT NULL',",
				"     format: 'query') ~> Controles",
				"source(output(",
				"          entrega_id as string,",
				"          boleta_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          paquete_id as string,",
				"          paquete_nombre as string,",
				"          fecha_entrega as string,",
				"          lote_produccion as string,",
				"          peso_paquete_kg as string,",
				"          fecha_proxima_entrega as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    entrega_id,\\r\\n    boleta_id,\\r\\n    TRIM(ci_beneficiaria)                      AS ci_beneficiaria,\\r\\n    establecimiento_id,\\r\\n    paquete_id,\\r\\n    TRIM(paquete_nombre)                       AS paquete_nombre,\\r\\n    TRIM(fecha_entrega)                        AS fecha_entrega,\\r\\n    NULLIF(TRIM(lote_produccion), \\'\\')         AS lote_produccion,\\r\\n    peso_paquete_kg,\\r\\n    TRIM(fecha_proxima_entrega)               AS fecha_proxima_entrega\\r\\nFROM bronze.sup_entregas\\r\\nWHERE NULLIF(TRIM(ci_beneficiaria), \\'\\') IS NOT NULL',",
				"     format: 'query') ~> Entregas",
				"source(output(",
				"          establecimiento_id as string,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    establecimiento_id,\\r\\n    TRIM(codigo_snis)       AS codigo_snis,\\r\\n    TRIM(nombre)            AS nombre,\\r\\n    TRIM(tipo)              AS tipo,\\r\\n    TRIM(nivel_atencion)    AS nivel_atencion,\\r\\n    TRIM(municipio)         AS municipio,\\r\\n    TRIM(departamento)      AS departamento,\\r\\n    NULLIF(TRIM(red_salud), \\'\\')  AS red_salud,\\r\\n    TRIM(estado) AS estado\\r\\nFROM bronze.sup_establecimientos\\r\\nWHERE NULLIF(TRIM(codigo_snis), \\'\\') IS NOT NULL',",
				"     format: 'query') ~> Establecimientos",
				"source(output(",
				"          inscripcion_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          fecha_inscripcion as string,",
				"          semana_gestacion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    inscripcion_id,\\r\\n    TRIM(ci_beneficiaria)                      AS ci_beneficiaria,\\r\\n    establecimiento_id,\\r\\n    TRIM(fecha_inscripcion)                    AS fecha_inscripcion,\\r\\n    semana_gestacion,\\r\\n    TRIM(estado)              AS estado\\r\\nFROM bronze.sup_inscripciones\\r\\nWHERE NULLIF(TRIM(ci_beneficiaria), \\'\\') IS NOT NULL',",
				"     format: 'query') ~> Inscripciones",
				"Boletas derive(boleta_id = toInteger(boleta_id),",
				"          control_id = toInteger(control_id),",
				"          estado = initCap(lower(trim(estado))),",
				"          fecha_emision = iif(isNull(fecha_emision) || trim(toString(fecha_emision)) == '',\r",
				"    toDate(null()),\r",
				"iif(regexMatch(trim(toString(fecha_emision)), '[0-9]{2}-[0-9]{2}-[0-9]{4}'),\r",
				"    toDate(trim(toString(fecha_emision)), 'dd-MM-yyyy'),\r",
				"iif(regexMatch(trim(toString(fecha_emision)), '[0-9]{4}-[0-9]{2}-[0-9]{2}'),\r",
				"    toDate(trim(toString(fecha_emision)), 'yyyy-MM-dd'),\r",
				"iif(regexMatch(trim(toString(fecha_emision)), '[0-9]{2}/[0-9]{2}/[0-9]{4}') && toInteger(left(trim(toString(fecha_emision)),2)) > 12,\r",
				"    toDate(trim(toString(fecha_emision)), 'dd/MM/yyyy'),\r",
				"    toDate(trim(toString(fecha_emision)), 'MM/dd/yyyy')\r",
				"))))) ~> correccion",
				"CatalogoPaquetes derive(peso_estandar_kg = toDecimal(peso_estandar_kg, 10, 2),",
				"          costo_estimado_bs = toDecimal(costo_estimado_bs, 10, 2),",
				"          paquete_id = toInteger(paquete_id)) ~> numerosdecimales",
				"Controles derive(ci_beneficiaria = replace(trim(ci_beneficiaria), '-', ''),",
				"          control_id = toInteger(control_id),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          nro_control = toInteger(nro_control),",
				"          semana_gestacion = toInteger(semana_gestacion),",
				"          fecha_control = iif(isNull(fecha_control) || trim(toString(fecha_control)) == '',     toDate(null()), iif(regexMatch(trim(toString(fecha_control)), '[0-9]{2}-[0-9]{2}-[0-9]{4}'),     toDate(trim(toString(fecha_control)), 'dd-MM-yyyy'), iif(regexMatch(trim(toString(fecha_control)), '[0-9]{4}-[0-9]{2}-[0-9]{2}'),     toDate(trim(toString(fecha_control)), 'yyyy-MM-dd'), iif(regexMatch(trim(toString(fecha_control)), '[0-9]{2}/[0-9]{2}/[0-9]{4}') && toInteger(left(trim(toString(fecha_control)),2)) > 12,     toDate(trim(toString(fecha_control)), 'dd/MM/yyyy'),     toDate(trim(toString(fecha_control)), 'MM/dd/yyyy') )))),",
				"          presion_sistolica = toInteger(trim(split(presion_arterial, '/')[1])),",
				"          presion_diastolica = toInteger(trim(split(presion_arterial, '/')[2]))) ~> arreglo",
				"Entregas derive(entrega_id = toInteger(entrega_id),",
				"          boleta_id = toInteger(boleta_id),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          paquete_id = toInteger(paquete_id),",
				"          fecha_entrega = iif(isNull(fecha_entrega) || trim(toString(fecha_entrega)) == '',    toDate(null()),iif(regexMatch(trim(toString(fecha_entrega)), '[0-9]{2}-[0-9]{2}-[0-9]{4}'),    toDate(trim(toString(fecha_entrega)), 'dd-MM-yyyy'),iif(regexMatch(trim(toString(fecha_entrega)), '[0-9]{4}-[0-9]{2}-[0-9]{2}'),    toDate(trim(toString(fecha_entrega)), 'yyyy-MM-dd'),iif(regexMatch(trim(toString(fecha_entrega)), '[0-9]{2}/[0-9]{2}/[0-9]{4}') && toInteger(left(trim(toString(fecha_entrega)),2)) > 12,    toDate(trim(toString(fecha_entrega)), 'dd/MM/yyyy'),    toDate(trim(toString(fecha_entrega)), 'MM/dd/yyyy'))))),",
				"          fecha_proxima_entrega = iif(isNull(fecha_proxima_entrega) || trim(toString(fecha_proxima_entrega)) == '',\r",
				"    toDate(null()),\r",
				"iif(regexMatch(trim(toString(fecha_proxima_entrega)), '[0-9]{2}-[0-9]{2}-[0-9]{4}'),\r",
				"    toDate(trim(toString(fecha_proxima_entrega)), 'dd-MM-yyyy'),\r",
				"iif(regexMatch(trim(toString(fecha_proxima_entrega)), '[0-9]{4}-[0-9]{2}-[0-9]{2}'),\r",
				"    toDate(trim(toString(fecha_proxima_entrega)), 'yyyy-MM-dd'),\r",
				"iif(regexMatch(trim(toString(fecha_proxima_entrega)), '[0-9]{2}/[0-9]{2}/[0-9]{4}') && toInteger(left(trim(toString(fecha_proxima_entrega)),2)) > 12,\r",
				"    toDate(trim(toString(fecha_proxima_entrega)), 'dd/MM/yyyy'),\r",
				"    toDate(trim(toString(fecha_proxima_entrega)), 'MM/dd/yyyy')\r",
				")))),",
				"          peso_paquete_kg = toDecimal(peso_paquete_kg, 10, 3),",
				"          ci_beneficiaria = iif(regexMatch(upper(trim(ci_beneficiaria)), '[A-Z]{2}-?[0-9]+'),\r",
				"    regexReplace(upper(trim(ci_beneficiaria)), '([A-Z]{2})-?([0-9]+)', '$2$1'),\r",
				"iif(regexMatch(upper(trim(ci_beneficiaria)), '[0-9]+-?[A-Z]{2}'),\r",
				"    regexReplace(replace(upper(trim(ci_beneficiaria)), '-', ''), '([0-9]+)([A-Z]{2})', '$1$2'),\r",
				"    replace(replace(upper(trim(ci_beneficiaria)), '-', ''), ' ', '')\r",
				"))) ~> Datos",
				"Inscripciones derive(inscripcion_id = toInteger(inscripcion_id),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          semana_gestacion = toInteger(semana_gestacion),",
				"          estado =  initCap(lower(trim(estado))),",
				"          fecha_inscripcion = iif(isNull(fecha_inscripcion) || trim(toString(fecha_inscripcion)) == '',\r",
				"    toDate(null()),\r",
				"iif(regexMatch(trim(toString(fecha_inscripcion)), '[0-9]{2}-[0-9]{2}-[0-9]{4}'),\r",
				"    toDate(trim(toString(fecha_inscripcion)), 'dd-MM-yyyy'),\r",
				"iif(regexMatch(trim(toString(fecha_inscripcion)), '[0-9]{4}-[0-9]{2}-[0-9]{2}'),\r",
				"    toDate(trim(toString(fecha_inscripcion)), 'yyyy-MM-dd'),\r",
				"iif(regexMatch(trim(toString(fecha_inscripcion)), '[0-9]{2}/[0-9]{2}/[0-9]{4}') && toInteger(left(trim(toString(fecha_inscripcion)),2)) > 12,\r",
				"    toDate(trim(toString(fecha_inscripcion)), 'dd/MM/yyyy'),\r",
				"    toDate(trim(toString(fecha_inscripcion)), 'MM/dd/yyyy')\r",
				"))))) ~> derivedColumn1",
				"Establecimientos derive(establecimiento_id = toInteger(establecimiento_id),",
				"          departamento = iif(upper(trim(departamento)) == 'LP', 'La Paz', iif(upper(trim(departamento)) == 'CB', 'Cochabamba', iif(upper(trim(departamento)) == 'SC', 'Santa Cruz', iif(upper(trim(departamento)) == 'OR', 'Oruro', trim(departamento)))))) ~> derivedColumn2",
				"derivedColumn2 derive(departamento = iif(upper(trim(departamento)) == 'BN', 'Beni', iif(upper(trim(departamento)) == 'CH', 'Chuquisaca', iif(upper(trim(departamento)) == 'PT', 'Potosi', iif(upper(trim(departamento)) == 'TJ', 'Tarija', trim(departamento)))))) ~> derivedColumn3",
				"derivedColumn3 derive(departamento = iif(upper(trim(departamento)) == 'LP', 'La Paz', iif(upper(trim(departamento)) == 'CB', 'Cochabamba', iif(upper(trim(departamento)) == 'PD', 'Pando', iif(upper(trim(departamento)) == 'OR', 'Oruro', trim(departamento)))))) ~> derivedColumn4",
				"correccion sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          boleta_id as integer,",
				"          control_id as integer,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as date,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          boleta_id,",
				"          control_id,",
				"          ci_beneficiaria,",
				"          nro_boleta,",
				"          fecha_emision,",
				"          estado",
				"     )) ~> sink1",
				"numerosdecimales sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          paquete_id as integer,",
				"          nombre as string,",
				"          contenido as string,",
				"          tipo_paquete as string,",
				"          peso_estandar_kg as decimal(6,2),",
				"          costo_estimado_bs as decimal(10,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          paquete_id,",
				"          nombre,",
				"          contenido,",
				"          peso_estandar_kg,",
				"          costo_estimado_bs",
				"     )) ~> sink2",
				"arreglo sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          control_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          nro_control as integer,",
				"          fecha_control as date,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as decimal(5,2),",
				"          presion_sistolica as integer,",
				"          presion_diastolica as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          control_id,",
				"          ci_beneficiaria,",
				"          establecimiento_id,",
				"          nro_control,",
				"          fecha_control,",
				"          semana_gestacion,",
				"          presion_sistolica,",
				"          presion_diastolica",
				"     )) ~> sink3",
				"Datos sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_id as integer,",
				"          boleta_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          paquete_id as integer,",
				"          fecha_entrega as date,",
				"          nro_lote as string,",
				"          empresa_lote as string,",
				"          peso_paquete_kg as decimal(6,2)",
				"     ),",
