				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          produccion_id,",
				"          empresa_id,",
				"          planta_id,",
				"          producto_id,",
				"          nro_lote,",
				"          fecha_produccion,",
				"          cantidad,",
				"          unidad,",
