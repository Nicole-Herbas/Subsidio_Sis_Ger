			"scriptLines": [
				"source(output(",
				"          control_id as string,",
				"          produccion_id as string,",
				"          nro_lote as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          parametro as string,",
				"          valor_medido as string,",
				"          unidad_medida as string,",
				"          valor_minimo as string,",
				"          valor_maximo as string,",
				"          cumple as string,",
				"          inspector as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    control_id,\\r\\n    produccion_id,\\r\\n    TRIM(nro_lote)                             AS nro_lote,\\r\\n    nro_control,\\r\\n    fecha_control,\\r\\n    TRIM(parametro)                        AS parametro,\\r\\n    valor_medido,\\r\\n    TRIM(unidad_medida)                        AS unidad_medida,\\r\\n    valor_minimo,\\r\\n    valor_maximo,\\r\\n    LOWER(TRIM(cumple))                         AS cumple,\\r\\n    NULLIF(LOWER(TRIM(inspector)), \\'\\')          AS inspector\\r\\nFROM bronze.sedem_control_calidad\\r\\nWHERE NULLIF(TRIM(nro_lote), \\'\\') IS NOT NULL',",
				"     format: 'query') ~> ControlCalidad",
				"source(output(",
				"          empresa_id as string,",
				"          sigla as string,",
				"          nombre as string,",
				"          descripcion as string,",
				"          nit as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    empresa_id, TRIM(sigla) AS sigla, TRIM(nombre) AS nombre,\\r\\n    TRIM(descripcion) AS descripcion, TRIM(nit) AS nit,\\r\\n    TRIM(municipio) AS municipio, TRIM(departamento) AS departamento,\\r\\n    TRIM(estado) AS estado\\r\\nFROM bronze.sedem_empresas',",
				"     format: 'query') ~> Empresas",
				"source(output(",
				"          inventario_id as string,",
				"          empresa_id as string,",
				"          producto_id as string,",
				"          nro_lote as string,",
				"          cantidad_producida as string,",
				"          cantidad_despachada as string,",
				"          cantidad_disponible as string,",
				"          estado as string,",
				"          fecha_ultimo_movimiento as string,",
				"          almacen as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    inventario_id,\\r\\n    empresa_id,\\r\\n    producto_id,\\r\\n    TRIM(nro_lote)                             AS nro_lote,\\r\\n    cantidad_producida,\\r\\n    cantidad_despachada,\\r\\n    cantidad_disponible,\\r\\n    LOWER(TRIM(estado))              AS estado,\\r\\n    fecha_ultimo_movimiento,\\r\\n    almacen\\r\\nFROM bronze.sedem_inventario\\r\\nWHERE NULLIF(TRIM(nro_lote), \\'\\') IS NOT NULL',",
				"     format: 'query') ~> Inventario",
				"source(output(",
				"          planta_id as string,",
				"          empresa_id as string,",
				"          nombre as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          tipo as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    planta_id, empresa_id, TRIM(nombre) AS nombre,\\r\\n    TRIM(municipio) AS municipio, TRIM(departamento) AS departamento,\\r\\n    TRIM(tipo) AS tipo,\\r\\n    TRIM(estado) AS estado\\r\\nFROM bronze.sedem_plantas',",
				"     format: 'query') ~> Plantas",
				"source(output(",
				"          produccion_id as string,",
				"          empresa_id as string,",
				"          planta_id as string,",
				"          producto_id as string,",
				"          nro_lote as string,",
				"          fecha_produccion as string,",
				"          cantidad as string,",
				"          unidad as string,",
				"          turno as string,",
				"          responsable as string,",
				"          costo_produccion as string,",
				"          estado as string,",
				"          fecha_vencimiento as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    produccion_id,\\r\\n    empresa_id,\\r\\n    planta_id,\\r\\n    producto_id,\\r\\n    TRIM(nro_lote)                             AS nro_lote,\\r\\n    TRIM(fecha_produccion)                     AS fecha_produccion,\\r\\n    cantidad,\\r\\n    LOWER(TRIM(unidad))                        AS unidad,\\r\\n    LOWER(TRIM(turno))               AS turno,\\r\\n    responsable,\\r\\n    costo_produccion,\\r\\n    LOWER(TRIM(estado))              AS estado,\\r\\n    NULLIF(TRIM(fecha_vencimiento), \\'\\')       AS fecha_vencimiento\\r\\nFROM bronze.sedem_produccion\\r\\nWHERE NULLIF(TRIM(nro_lote), \\'\\') IS NOT NULL',",
				"     format: 'query') ~> Produccion",
				"source(output(",
				"          producto_id as string,",
				"          empresa_id as string,",
				"          nombre as string,",
				"          categoria as string,",
				"          presentacion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    producto_id, empresa_id, TRIM(nombre) AS nombre,\\r\\n    TRIM(categoria) AS categoria, TRIM(presentacion) AS presentacion,\\r\\n    LOWER(TRIM(estado)) AS estado\\r\\nFROM bronze.sedem_productos',",
				"     format: 'query') ~> Productos",
				"ControlCalidad derive(fecha_control = iif(isNull(fecha_control) || trim(toString(fecha_control)) == '',     toDate(null()), iif(regexMatch(trim(toString(fecha_control)), '[0-9]{2}-[0-9]{2}-[0-9]{4}'),     toDate(trim(toString(fecha_control)), 'dd-MM-yyyy'), iif(regexMatch(trim(toString(fecha_control)), '[0-9]{4}-[0-9]{2}-[0-9]{2}'),     toDate(trim(toString(fecha_control)), 'yyyy-MM-dd'), iif(regexMatch(trim(toString(fecha_control)), '[0-9]{2}/[0-9]{2}/[0-9]{4}'),     toDate(trim(toString(fecha_control)), 'MM/dd/yyyy'),     toDate(null()) )))),",
				"          parametro = iif(lower(trim(parametro))=='graamaje','Gramaje', iif(lower(trim(parametro))=='impurezas','Impurezas', iif(lower(trim(parametro))=='huedad','Humedad', initCap(lower(trim(parametro)))))),",
				"          cumple = iif(lower(trim(cumple)) == 'sí' || lower(trim(cumple)) == 'si' || lower(trim(cumple)) == 's' || lower(trim(cumple)) == 'yes' || lower(trim(cumple)) == 'y' || lower(trim(cumple)) == '1', 'Sí', 'No'),",
				"          valor_medido = toDecimal(valor_medido, 10, 2),",
				"          valor_minimo = toDecimal(valor_minimo, 10, 2),",
				"          control_id = toInteger(control_id),",
				"          produccion_id = toInteger(produccion_id),",
				"          nro_control = toInteger(nro_control)) ~> TipoDato",
				"Empresas derive(empresa_id = toInteger(empresa_id)) ~> trim",
				"Inventario derive(inventario_id = toInteger(inventario_id),",
				"          empresa_id = toInteger(empresa_id),",
				"          producto_id = toInteger(producto_id),",
				"          cantidad_producida = toInteger(cantidad_producida),",
				"          cantidad_despachada = toInteger(cantidad_despachada),",
				"          cantidad_disponible = toInteger(cantidad_disponible)) ~> toint",
				"toint derive(fecha_ultimo_movimiento = iif(isNull(fecha_ultimo_movimiento) || trim(toString(fecha_ultimo_movimiento)) == '',\r",
				"    toDate(null()),\r",
				"iif(regexMatch(trim(toString(fecha_ultimo_movimiento)), '[0-9]{2}-[0-9]{2}-[0-9]{4}'),\r",
				"    toDate(trim(toString(fecha_ultimo_movimiento)), 'dd-MM-yyyy'),\r",
				"iif(regexMatch(trim(toString(fecha_ultimo_movimiento)), '[0-9]{4}-[0-9]{2}-[0-9]{2}'),\r",
				"    toDate(trim(toString(fecha_ultimo_movimiento)), 'yyyy-MM-dd'),\r",
				"iif(regexMatch(trim(toString(fecha_ultimo_movimiento)), '[0-9]{2}/[0-9]{2}/[0-9]{4}'),\r",
				"    toDate(trim(toString(fecha_ultimo_movimiento)), 'MM/dd/yyyy'),\r",
				"    toDate(null())\r",
				")))),",
				"          estado = initCap(lower(trim(estado))),",
				"          almacen = initCap(lower(trim(almacen)))) ~> datos",
				"Plantas derive(planta_id = toInteger(planta_id),",
				"          empresa_id = toInteger(empresa_id)) ~> interger",
				"Produccion derive(produccion_id = toInteger(produccion_id),",
				"          empresa_id = toInteger(empresa_id),",
				"          planta_id = toInteger(planta_id),",
				"          producto_id = toInteger(producto_id),",
				"          estado =  initCap(lower(trim(estado))),",
				"          costo_produccion = toDecimal(costo_produccion, 12, 2)) ~> conv",
				"conv derive(fecha_produccion = iif(isNull(fecha_produccion) || trim(toString(fecha_produccion)) == '',\r",
				"    toDate(null()),\r",
				"iif(regexMatch(trim(toString(fecha_produccion)), '[0-9]{2}-[0-9]{2}-[0-9]{4}'),\r",
				"    toDate(trim(toString(fecha_produccion)), 'dd-MM-yyyy'),\r",
				"iif(regexMatch(trim(toString(fecha_produccion)), '[0-9]{4}-[0-9]{2}-[0-9]{2}'),\r",
				"    toDate(trim(toString(fecha_produccion)), 'yyyy-MM-dd'),\r",
				"iif(regexMatch(trim(toString(fecha_produccion)), '[0-9]{2}/[0-9]{2}/[0-9]{4}'),\r",
				"    toDate(trim(toString(fecha_produccion)), 'MM/dd/yyyy'),\r",
				"    toDate(null())\r",
				")))),",
				"          fecha_vencimiento = iif(isNull(fecha_vencimiento) || trim(toString(fecha_vencimiento)) == '',\r",
				"    toDate(null()),\r",
				"iif(regexMatch(trim(toString(fecha_vencimiento)), '[0-9]{2}-[0-9]{2}-[0-9]{4}'),\r",
				"    toDate(trim(toString(fecha_vencimiento)), 'dd-MM-yyyy'),\r",
				"iif(regexMatch(trim(toString(fecha_vencimiento)), '[0-9]{4}-[0-9]{2}-[0-9]{2}'),\r",
				"    toDate(trim(toString(fecha_vencimiento)), 'yyyy-MM-dd'),\r",
				"iif(regexMatch(trim(toString(fecha_vencimiento)), '[0-9]{2}/[0-9]{2}/[0-9]{4}'),\r",
				"    toDate(trim(toString(fecha_vencimiento)), 'MM/dd/yyyy'),\r",
				"    toDate(null())\r",
				")))),",
				"          costo_produccion = toDecimal(costo_produccion, 10, 2),",
				"          cantidad = toInteger(toDecimal(trim(toString(cantidad)), 10, 2)),",
				"          unidad = initCap(lower(trim(unidad))),",
				"          turno = initCap(lower(trim(turno)))) ~> derivedColumn1",
				"Productos derive(producto_id = toInteger(producto_id),",
				"          empresa_id = toInteger(empresa_id),",
				"          estado = initCap(lower(trim(estado)))) ~> derivedColumn2",
				"TipoDato sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          control_id as integer,",
				"          produccion_id as integer,",
				"          nro_lote as string,",
				"          nro_control as integer,",
				"          fecha_control as date,",
				"          parametro as string,",
				"          valor_medido as decimal(10,4),",
				"          unidad_medida as string,",
				"          valor_minimo as decimal(10,4),",
				"          valor_maximo as decimal(10,4),",
				"          cumple as boolean,",
				"          inspector as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          control_id,",
				"          produccion_id,",
				"          nro_lote,",
				"          nro_control,",
				"          fecha_control,",
				"          parametro,",
				"          valor_medido,",
				"          unidad_medida,",
				"          valor_minimo,",
				"          inspector",
				"     )) ~> sink1",
				"trim sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          empresa_id as integer,",
				"          sigla as string,",
				"          nombre as string,",
				"          descripcion as string,",
				"          nit as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          empresa_id,",
				"          sigla,",
				"          nombre,",
				"          descripcion,",
				"          nit,",
				"          municipio,",
				"          departamento,",
				"          estado",
				"     )) ~> sink2",
				"datos sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          inventario_id as integer,",
				"          empresa_id as integer,",
				"          producto_id as integer,",
				"          nro_lote as string,",
				"          cantidad_producida as integer,",
				"          cantidad_despachada as integer,",
				"          cantidad_disponible as integer,",
				"          estado as string,",
				"          fecha_ultimo_movimiento as date,",
				"          almacen as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          inventario_id,",
				"          empresa_id,",
				"          producto_id,",
				"          nro_lote,",
				"          cantidad_producida,",
				"          cantidad_despachada,",
				"          cantidad_disponible,",
				"          estado,",
				"          fecha_ultimo_movimiento,",
				"          almacen",
				"     )) ~> sink3",
				"interger sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          planta_id as integer,",
				"          empresa_id as integer,",
				"          nombre as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          tipo as string,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          planta_id,",
				"          empresa_id,",
				"          nombre,",
				"          municipio,",
				"          departamento,",
				"          tipo,",
				"          estado",
				"     )) ~> sink4",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          produccion_id as integer,",
				"          empresa_id as integer,",
				"          planta_id as integer,",
				"          producto_id as integer,",
				"          nro_lote as string,",
				"          fecha_produccion as date,",
				"          cantidad as decimal(12,2),",
				"          unidad as string,",
				"          turno as string,",
				"          responsable as string,",
				"          costo_produccion as decimal(14,2),",
				"          estado as string,",
				"          fecha_vencimiento as date",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
