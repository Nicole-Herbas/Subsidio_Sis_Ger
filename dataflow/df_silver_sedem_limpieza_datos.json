				"          responsable,",
				"          costo_produccion,",
				"          estado,",
				"          fecha_vencimiento",
				"     )) ~> sink5",
				"derivedColumn2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
