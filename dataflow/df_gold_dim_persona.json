{
	"name": "df_gold_dim_persona",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_segip_personas",
						"type": "DatasetReference"
					},
					"name": "personas"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_persona",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "aggregate1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ci as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          fecha_nacimiento as date,",
				"          estado_civil as string,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string,",
				"          genero as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    ci,\\r\\n    nombres,\\r\\n    apellido_paterno,\\r\\n    fecha_nacimiento,\\r\\n    estado_civil,\\r\\n    profesion,\\r\\n    nivel_estudios,\\r\\n    municipio_residencia,\\r\\n    genero\\r\\nFROM silver.segip_personas',",
				"     format: 'query') ~> personas",
				"personas aggregate(groupBy(ci),",
				"     nombres = first(nombres),",
				"          apellido_paterno = first(apellido_paterno),",
				"          fecha_nacimiento = first(fecha_nacimiento),",
				"          estado_civil = first(estado_civil),",
				"          profesion = first(profesion),",
				"          nivel_estudios = first(nivel_estudios),",
				"          municipio_residencia = first(municipio_residencia),",
				"          genero = first(genero)) ~> aggregate1",
				"aggregate1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          persona_sk as integer,",
				"          ci as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          fecha_nacimiento as date,",
				"          genero as string,",
				"          estado_civil as string,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string,",
				"          ci_padre as string,",
				"          ci_madre as string,",
				"          ci_conyuge as string,",
				"          numero_hijos as integer,",
				"          fecha_emision_ci as date",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          ci,",
				"          nombres,",
				"          apellido_paterno,",
				"          fecha_nacimiento,",
				"          genero,",
				"          estado_civil,",
				"          profesion,",
				"          nivel_estudios,",
				"          municipio_residencia",
				"     )) ~> sink1"
			]
		}
	}
}