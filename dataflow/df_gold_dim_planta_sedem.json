{
	"name": "df_gold_dim_planta_sedem",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_sedem_plantas",
						"type": "DatasetReference"
					},
					"name": "plantas"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_empresa_sedem",
						"type": "DatasetReference"
					},
					"name": "empresa"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_planta_sedem",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "lookup1"
				},
				{
					"name": "select1"
				},
				{
					"name": "aggregate1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          planta_id as integer,",
				"          empresa_id as integer,",
				"          nombre as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          tipo as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT planta_id, empresa_id, nombre, municipio, departamento, tipo, estado\\r\\nFROM silver.sedem_plantas',",
				"     format: 'query') ~> plantas",
				"source(output(",
				"          empresa_sk as integer,",
				"          empresa_id as integer,",
				"          sigla as string,",
				"          nombre as string,",
				"          descripcion as string,",
				"          nit as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> empresa",
				"plantas, empresa lookup(plantas@empresa_id == empresa@empresa_id,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"lookup1 select(mapColumn(",
				"          planta_id,",
				"          nombre = plantas@nombre,",
				"          municipio = plantas@municipio,",
				"          departamento = plantas@departamento,",
				"          tipo,",
				"          estado = plantas@estado,",
				"          empresa_sk",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 aggregate(groupBy(planta_id),",
				"     nombre = first(nombre),",
				"          municipio = first(municipio),",
				"          departamento = first(departamento),",
				"          tipo = first(tipo),",
				"          estado = first(estado),",
				"          empresa_sk = first(empresa_sk)) ~> aggregate1",
				"aggregate1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          planta_sk as integer,",
				"          planta_id as integer,",
				"          empresa_sk as integer,",
				"          nombre as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          tipo as string,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          planta_id,",
				"          empresa_sk,",
				"          nombre,",
				"          municipio,",
				"          departamento,",
				"          tipo,",
				"          estado",
				"     )) ~> sink1"
			]
		}
	}
}