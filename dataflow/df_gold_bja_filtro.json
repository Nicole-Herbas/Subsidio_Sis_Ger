			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          control_pediatrico_id as integer,",
				"          ci_nino as string,",
				"          ci_madre as string,",
				"          establecimiento_id as integer,",
				"          nro_control as integer,",
				"          fecha_control as date,",
				"          peso_nino_kg as decimal(5,2),",
				"          talla_nino_cm as decimal(5,1),",
				"          vacuna_aplicada as string,",
				"          resultado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    control_pediatrico_id, ci_nino, ci_madre,\\r\\n    establecimiento_id, nro_control, fecha_control,\\r\\n    peso_nino_kg, talla_nino_cm, vacuna_aplicada, resultado\\r\\nFROM silver.bja_controles_pediatricos',",
				"     format: 'query') ~> ControlesPediatricos",
				"source(output(",
				"          control_prenatal_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          nro_control as integer,",
				"          fecha_control as date,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as decimal(5,2),",
				"          presion_sistolica as short,",
				"          presion_diastolica as short,",
				"          resultado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    control_prenatal_id, ci_beneficiaria, establecimiento_id,\\r\\n    nro_control, fecha_control, semana_gestacion,\\r\\n    peso_madre_kg, presion_sistolica, presion_diastolica, resultado\\r\\nFROM silver.bja_controles_prenatales',",
				"     format: 'query') ~> ControlesPrenatales",
				"source(output(",
				"          establecimiento_id as integer,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    establecimiento_id, codigo_snis, nombre, tipo,\\r\\n    nivel_atencion, municipio, departamento, red_salud, estado\\r\\nFROM silver.bja_establecimientos_salud',",
				"     format: 'query') ~> EstablecimientosSalud",
				"source(output(",
				"          inscripcion_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          fecha_inscripcion as date,",
				"          semana_gestacion as integer,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    inscripcion_id, ci_beneficiaria, establecimiento_id,\\r\\n    fecha_inscripcion, semana_gestacion, estado\\r\\nFROM silver.bja_inscripciones',",
				"     format: 'query') ~> Inscripciones",
				"source(output(",
				"          pago_id as integer,",
				"          ci_beneficiaria as string,",
				"          concepto_pago as string,",
				"          monto_bs as decimal(10,2),",
				"          fecha_pago as date,",
				"          estado_pago as string,",
				"          canal_pago as string,",
				"          nro_comprobante as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    pago_id, ci_beneficiaria, concepto_pago,\\r\\n    monto_bs, fecha_pago, estado_pago, canal_pago, nro_comprobante\\r\\nFROM silver.bja_pagos',",
				"     format: 'query') ~> Pagos",
				"source(output(",
				"          parto_id as integer,",
				"          ci_madre as string,",
				"          ci_recien_nacido as string,",
				"          establecimiento_id as integer,",
				"          fecha_parto as date,",
				"          tipo_parto as string,",
				"          peso_nacimiento_kg as decimal(5,3),",
				"          talla_nacimiento_cm as decimal(5,1)",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    parto_id, ci_madre, ci_recien_nacido,\\r\\n    establecimiento_id, fecha_parto, tipo_parto,\\r\\n    peso_nacimiento_kg, talla_nacimiento_cm\\r\\nFROM silver.bja_partos',",
				"     format: 'query') ~> Partos",
				"ControlesPediatricos sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          control_ped_bja_sk as integer,",
				"          control_ped_id_src as integer,",
				"          persona_sk_nino as integer,",
				"          persona_sk_madre as integer,",
				"          establecimiento_sk as integer,",
				"          fecha_control_sk as integer,",
				"          nro_control as integer,",
				"          peso_nino_kg as decimal(5,2),",
				"          talla_nino_cm as decimal(5,1),",
				"          vacuna_aplicada as string,",
				"          resultado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          nro_control,",
				"          resultado,",
				"          control_ped_id_src = control_pediatrico_id,",
				"          peso_nino_kg,",
				"          talla_nino_cm,",
				"          vacuna_aplicada",
				"     )) ~> sink1",
				"ControlesPrenatales sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          control_prenatal_bja_sk as integer,",
				"          control_prenatal_id_src as integer,",
				"          persona_sk as integer,",
				"          establecimiento_sk as integer,",
				"          fecha_control_sk as integer,",
				"          nro_control as integer,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as decimal(5,2),",
				"          presion_sistolica as integer,",
				"          presion_diastolica as integer,",
				"          resultado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          nro_control,",
				"          resultado,",
				"          control_prenatal_id_src = control_prenatal_id,",
				"          peso_madre_kg,",
				"          semana_gestacion,",
				"          presion_sistolica,",
				"          presion_diastolica",
				"     )) ~> sink2",
				"EstablecimientosSalud sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          establecimiento_sk as integer,",
				"          establecimiento_id as integer,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string,",
				"          sistema_origen as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          establecimiento_id,",
				"          codigo_snis,",
				"          nombre,",
				"          tipo,",
				"          nivel_atencion,",
				"          municipio,",
				"          departamento,",
				"          red_salud,",
				"          estado",
				"     )) ~> sink3",
				"Inscripciones sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          inscripcion_bja_sk as integer,",
				"          inscripcion_id_src as integer,",
				"          persona_sk as integer,",
				"          establecimiento_sk as integer,",
				"          fecha_inscripcion_sk as integer,",
				"          semana_gestacion as integer,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          semana_gestacion,",
				"          estado,",
				"          inscripcion_id_src = inscripcion_id",
				"     )) ~> sink4",
				"Pagos sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          pago_bja_sk as integer,",
				"          pago_id_src as integer,",
				"          persona_sk as integer,",
				"          fecha_pago_sk as integer,",
				"          concepto_pago as string,",
				"          tipo_evento as string,",
				"          monto_bs as decimal(10,2),",
				"          estado_pago as string,",
				"          canal_pago as string,",
				"          nro_comprobante as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          concepto_pago,",
				"          monto_bs,",
				"          estado_pago,",
				"          canal_pago,",
				"          nro_comprobante,",
				"          pago_id_src = pago_id",
				"     )) ~> sink5",
				"Partos sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          parto_bja_sk as integer,",
				"          parto_id_src as integer,",
				"          persona_sk_madre as integer,",
				"          persona_sk_nino as integer,",
				"          establecimiento_sk as integer,",
				"          fecha_parto_sk as integer,",
				"          tipo_parto as string,",
				"          peso_nacimiento_kg as decimal(5,3),",
				"          talla_nacimiento_cm as decimal(5,1)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          tipo_parto,",
				"          peso_nacimiento_kg,",
				"          talla_nacimiento_cm,",
				"          parto_id_src = parto_id",
				"     )) ~> sink6"
			]
		}
	}
}