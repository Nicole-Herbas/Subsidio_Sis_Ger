{
	"name": "df_gold_dim_establecimiento_salud",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_bja_establecimientos_salud",
						"type": "DatasetReference"
					},
					"name": "BJAestablecimiento"
				},
				{
					"dataset": {
						"referenceName": "silver_sup_establecimientos",
						"type": "DatasetReference"
					},
					"name": "SUPestablecimiento"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_establecimiento_salud",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "union1"
				},
				{
					"name": "aggregate1"
				},
				{
					"name": "aggregate2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          establecimiento_id as integer,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT establecimiento_id, codigo_snis, nombre, tipo,\\r\\n       nivel_atencion, municipio, departamento, red_salud, estado\\r\\nFROM silver.bja_establecimientos_salud',",
				"     format: 'query') ~> BJAestablecimiento",
				"source(output(",
				"          establecimiento_id as integer,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT establecimiento_id, codigo_snis, nombre, tipo,\\r\\n       nivel_atencion, municipio, departamento, red_salud, estado\\r\\nFROM silver.sup_establecimientos\\r\\nWHERE codigo_snis NOT IN (\\r\\n    SELECT codigo_snis FROM silver.bja_establecimientos_salud\\r\\n)',",
				"     format: 'query') ~> SUPestablecimiento",
				"BJAestablecimiento derive(sistema_origen = 'BJA') ~> derivedColumn1",
				"SUPestablecimiento derive(sistema_origen = 'SUP') ~> derivedColumn2",
				"derivedColumn1, derivedColumn2 union(byName: true)~> union1",
				"union1 aggregate(groupBy(establecimiento_id),",
				"     codigo_snis = first(codigo_snis),",
				"          nombre = first(nombre),",
				"          tipo = first(tipo),",
				"          nivel_atencion = first(nivel_atencion),",
				"          municipio = first(municipio),",
				"          departamento = first(departamento),",
				"          red_salud = first(red_salud),",
				"          estado = first(estado),",
				"          sistema_origen = first(sistema_origen)) ~> aggregate1",
				"aggregate1 aggregate(groupBy(codigo_snis),",
				"     establecimiento_id = first(establecimiento_id),",
				"          nombre = first(nombre),",
				"          tipo = first(tipo),",
				"          nivel_atencion = first(nivel_atencion),",
				"          municipio = first(municipio),",
				"          departamento = first(departamento),",
				"          red_salud = first(red_salud),",
				"          estado = first(estado),",
				"          sistema_origen = first(sistema_origen)) ~> aggregate2",
				"aggregate2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          establecimiento_sk as integer,",
				"          establecimiento_id as integer,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string,",
				"          sistema_origen as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          establecimiento_id,",
				"          codigo_snis,",
				"          nombre,",
				"          tipo,",
				"          nivel_atencion,",
				"          municipio,",
				"          departamento,",
				"          red_salud,",
				"          estado,",
				"          sistema_origen",
				"     )) ~> sink1"
			]
		}
	}
}