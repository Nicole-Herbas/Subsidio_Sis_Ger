				"typeProperties": {
					"scripts": [
						{
							"type": "NonQuery",
							"text": "INSERT INTO gold.dim_persona (ci, nombres)\nSELECT DISTINCT faltantes.ci_huerfano, 'Sin datos SEGIP'\nFROM (\n    SELECT ci_beneficiaria AS ci_huerfano FROM silver.bja_inscripciones\n    UNION\n    SELECT ci_beneficiaria FROM silver.bja_controles_prenatales\n    UNION\n    SELECT ci_madre        FROM silver.bja_partos\n    UNION\n    SELECT ci_recien_nacido FROM silver.bja_partos WHERE ci_recien_nacido IS NOT NULL\n    UNION\n    SELECT ci_beneficiaria FROM silver.bja_pagos\n    UNION\n    SELECT ci_nino         FROM silver.bja_controles_pediatricos\n    UNION\n    SELECT ci_madre        FROM silver.bja_controles_pediatricos\n    UNION\n    SELECT ci_beneficiaria FROM silver.sup_inscripciones\n    UNION\n    SELECT ci_beneficiaria FROM silver.sup_controles\n    UNION\n    SELECT ci_beneficiaria FROM silver.sup_boletas\n    UNION\n    SELECT ci_beneficiaria FROM silver.sup_entregas\n) AS faltantes\nWHERE faltantes.ci_huerfano IS NOT NULL\n  AND faltantes.ci_huerfano NOT IN (SELECT ci FROM gold.dim_persona);"
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}
